# ZapLivre Development Environment Variables
# Copy this file to .env and fill in your values.
# Every variable here is consumed by docker-compose.yml (or by the client apps
# where noted). Defaults are suitable for LOCAL DEVELOPMENT ONLY.

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=zaplivre
POSTGRES_USER=zaplivre
POSTGRES_PASSWORD=zaplivre_dev_password

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=zaplivre_redis_dev

# ─── TURN Server (coturn + turn-credentials) ────────────────────────────────
# TURN_STATIC_SECRET must match static-auth-secret in server/coturn/turnserver.conf
TURN_STATIC_SECRET=change_me_to_a_random_32_character_secret
TURN_USERNAME=zaplivre
TURN_PASSWORD=zaplivre_turn_dev
TURN_CREDENTIAL_TTL_SECONDS=3600

# Internal authentication between message-store and push-server (min. 32 chars)
PUSH_SERVICE_SECRET=change_me_to_a_random_32_character_secret
PUSH_MAX_CONCURRENT=128
TURN_MAX_CONCURRENT=64
ZAPLIVRE_IDENTITY_SERVER_URL=http://localhost:8083
TURN_REALM=zaplivre.app
# Public IP of the TURN relay (must be reachable by peers; 127.0.0.1 = local only)
TURN_EXTERNAL_IP=127.0.0.1

# ─── Bootstrap Node ──────────────────────────────────────────────────────────
# WARNING: the peer key is derived from this seed. Use a strong random value
# in production - anyone knowing the seed can impersonate the bootstrap node.
PEER_ID_SEED=bootstrap-1
RELAY_ENABLED=true
RELAY_MAX_CIRCUITS=100
RELAY_MAX_PER_PEER=10
RELAY_MAX_BYTES_PER_SEC=1000000

# ─── Message Store ───────────────────────────────────────────────────────────
ENABLE_TTL_CLEANUP=true

# ─── Push Notifications ─────────────────────────────────────────────────────
# FCM (Android) - HTTP v1: coloque o JSON do service account do Firebase em
# server/push/certs/fcm_service_account.json (Console > Service accounts)
# (nenhuma env adicional necessária - o caminho é fixo no container)
# APNs (iOS) - token-based auth: place the .p8 key at server/push/certs/apns_key.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=app.zaplivre.ios
APNS_PRODUCTION=false

# ─── Logging ─────────────────────────────────────────────────────────────────
RUST_LOG=info

# ─── Grafana (optional - monitoring profile) ─────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── Client apps (consumed by desktop/iOS/Android builds, not by compose) ───
# Local stack:
MESSAGE_STORE_URL=http://localhost:8080
SIGNALING_SERVER_URL=ws://localhost:8086/ws
# Production:
# MESSAGE_STORE_URL=https://store.associahub.com.br
# SIGNALING_SERVER_URL=wss://signaling.associahub.com.br/ws

# ─── Bootstrap node addresses (client-side) ─────────────────────────────────
BOOTSTRAP_NODE_1=localhost:4001
BOOTSTRAP_NODE_2=
BOOTSTRAP_NODE_3=
